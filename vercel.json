{
  "version": 2,
  "name": "aura-decor-hq",
  "builds": [
    { "src": "dashboard/aura-office.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/dashboard/aura-office.html" },
    { "src": "/(.*)", "dest": "/dashboard/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
