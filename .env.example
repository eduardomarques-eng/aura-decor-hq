# ============================================================
#  AURA Decor — Variáveis de Ambiente (.env.example)
#  Copie para .env e preencha seus valores
# ============================================================

GEMINI_API_KEY=sua-chave-gemini

# Obsidian Local REST API (plugin: https://github.com/coddingtonbear/obsidian-local-rest-api)
OBSIDIAN_API_KEY=sua-chave-obsidian
VAULT_PATH=C:\Users\SEU-USUARIO\OneDrive\Documentos\Obsidian Vault

# Shopify
SHOPIFY_STORE=sua-loja.myshopify.com
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# ── Redes Sociais (agentes autônomos) ──────────────────────────────────────
# Passo 1: Crie uma Página do Facebook para Aura Decore
# Passo 2: Acesse developers.facebook.com → Criar App → Facebook Login
# Passo 3: Gere um Page Access Token com permissões: pages_manage_posts, pages_read_engagement
# Passo 4: Cole os valores abaixo
FB_PAGE_ID=sua-page-id-aqui
FB_PAGE_TOKEN=EAAxxxxxxxxxxxxx

# Instagram Business (opcional — conta deve estar vinculada à Página FB)
INSTAGRAM_BUSINESS_ID=sua-instagram-business-id

# Serviços Locais
N8N_URL=http://localhost:5678
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AURA_BRIDGE=http://localhost:8001
